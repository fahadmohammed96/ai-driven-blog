# Copy to .env and adjust. Defaults match docker/compose.yaml.

# App
PORT=3000

# Postgres (dev compose)
DATABASE_URL=postgresql://blogs:blogs@localhost:5432/blogs

# MinIO (S3-compatible, dev compose)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=blogs-media
MINIO_CONSOLE=http://localhost:9001

# Mailhog (dev SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
MAILHOG_UI=http://localhost:8025

# Auth (founder login — see ADR-0010). In dev set FOUNDER_PASSWORD (hashed at
# boot); in prod set FOUNDER_PASSWORD_HASH instead. Always set a real JWT_SECRET.
FOUNDER_EMAIL=founder@example.com
FOUNDER_PASSWORD=change-me-in-dev
JWT_SECRET=dev-insecure-change-me

# AI (Anthropic) — set your key for live generation (see Fase 0 AI pipeline)
ANTHROPIC_API_KEY=
