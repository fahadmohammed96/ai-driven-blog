{
  "name": "blogs-manager",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "stack:up": "docker compose -f docker/compose.yaml up -d",
    "stack:down": "docker compose -f docker/compose.yaml down",
    "stack:check": "node apps/api/scripts/check-stack.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
